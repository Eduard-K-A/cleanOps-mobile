{
  "expo": {
    "name": "CleanOps",
    "slug": "cleanops-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cleanops",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1565C0"
      },
      "package": "com.cleanops.mobile"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cleanops.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
